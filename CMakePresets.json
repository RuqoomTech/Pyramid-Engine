{
  "version": 4,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 23,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "vs2022-debug",
      "displayName": "VS2022 Debug",
      "generator": "Visual Studio 17 2022",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/build/debug",
      "cacheVariables": {
        "PYRAMID_BUILD_EXAMPLES": "ON",
        "PYRAMID_BUILD_TESTS": "OFF",
        "PYRAMID_WARNINGS_AS_ERRORS": "OFF"
      }
    },
    {
      "name": "vs2022-debug-tests",
      "displayName": "VS2022 Debug + Tests",
      "inherits": "vs2022-debug",
      "binaryDir": "${sourceDir}/build/debug-tests",
      "cacheVariables": {
        "PYRAMID_BUILD_TESTS": "ON"
      }
    },
    {
      "name": "vs2022-release-tests",
      "displayName": "VS2022 Release + Tests",
      "inherits": "vs2022-debug-tests",
      "binaryDir": "${sourceDir}/build/release-tests"
    }
  ],
  "buildPresets": [
    {
      "name": "build-debug",
      "configurePreset": "vs2022-debug",
      "configuration": "Debug"
    },
    {
      "name": "build-debug-tests",
      "configurePreset": "vs2022-debug-tests",
      "configuration": "Debug"
    },
    {
      "name": "build-release-tests",
      "configurePreset": "vs2022-release-tests",
      "configuration": "Release"
    }
  ],
  "testPresets": [
    {
      "name": "test-debug",
      "configurePreset": "vs2022-debug-tests",
      "configuration": "Debug",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "test-release",
      "configurePreset": "vs2022-release-tests",
      "configuration": "Release",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
