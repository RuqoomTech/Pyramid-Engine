{
  "version": 4,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 23,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "ninja-base",
      "hidden": true,
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "PYRAMID_BUILD_EXAMPLES": "ON",
        "PYRAMID_BUILD_TESTS": "OFF",
        "PYRAMID_WARNINGS_AS_ERRORS": "OFF"
      }
    },
    {
      "name": "gcc-base",
      "hidden": true,
      "inherits": "ninja-base",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "gcc",
        "CMAKE_CXX_COMPILER": "g++"
      }
    },
    {
      "name": "clang-base",
      "hidden": true,
      "inherits": "ninja-base",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++"
      }
    },
    {
      "name": "gcc-debug",
      "displayName": "GCC Debug",
      "inherits": "gcc-base",
      "binaryDir": "${sourceDir}/build/gcc-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "gcc-debug-tests",
      "displayName": "GCC Debug + Tests",
      "inherits": "gcc-debug",
      "binaryDir": "${sourceDir}/build/gcc-debug-tests",
      "cacheVariables": {
        "PYRAMID_BUILD_TESTS": "ON"
      }
    },
    {
      "name": "gcc-release-tests",
      "displayName": "GCC Release + Tests",
      "inherits": "gcc-debug-tests",
      "binaryDir": "${sourceDir}/build/gcc-release-tests",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "clang-debug-tests",
      "displayName": "Clang Debug + Tests",
      "inherits": "clang-base",
      "binaryDir": "${sourceDir}/build/clang-debug-tests",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "PYRAMID_BUILD_TESTS": "ON"
      }
    },
    {
      "name": "clang-release-tests",
      "displayName": "Clang Release + Tests",
      "inherits": "clang-debug-tests",
      "binaryDir": "${sourceDir}/build/clang-release-tests",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "build-gcc-debug",
      "configurePreset": "gcc-debug"
    },
    {
      "name": "build-gcc-debug-tests",
      "configurePreset": "gcc-debug-tests"
    },
    {
      "name": "build-gcc-release-tests",
      "configurePreset": "gcc-release-tests"
    },
    {
      "name": "build-clang-debug-tests",
      "configurePreset": "clang-debug-tests"
    },
    {
      "name": "build-clang-release-tests",
      "configurePreset": "clang-release-tests"
    }
  ],
  "testPresets": [
    {
      "name": "test-gcc-debug",
      "configurePreset": "gcc-debug-tests",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "test-gcc-release",
      "configurePreset": "gcc-release-tests",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "test-clang-debug",
      "configurePreset": "clang-debug-tests",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "test-clang-release",
      "configurePreset": "clang-release-tests",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
